# ============================================================================
# Presidio Internal Research Agent — copy to `.env` and fill in values.
#   cp .env.example .env
# ============================================================================

# --- LLM (Ollama local default) ---------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=phi3
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- RAG settings -----------------------------------------------------------
HR_DATA_DIR=data/hr_policies
INDEX_DIR=index
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4

# --- Google Docs MCP (insurance queries) ------------------------------------
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DOCS_FOLDER_ID=
GOOGLE_DOC_IDS=

# Local mirror used when Google credentials are not configured
INSURANCE_DATA_DIR=data/insurance

# --- Web search -------------------------------------------------------------
TAVILY_API_KEY=
