# ============================================================================
# RAG Chatbot configuration — copy this file to `.env` and fill in values.
#   cp .env.example .env
# ============================================================================
# Which backend generates answers / creates embeddings.
#   LLM_BACKEND   : ollama | azure | claude
#   EMBED_BACKEND : ollama | azure
LLM_BACKEND=ollama
EMBED_BACKEND=ollama

# --- Ollama (local, default) ------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=phi3
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Azure OpenAI -----------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_DEPLOYMENT_NAME=gpt-4o
AZURE_EMBED_DEPLOYMENT_NAME=text-embedding-3-small
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_VERSION=2024-02-15-preview

# --- Anthropic / Claude -----------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- RAG parameters ---------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
